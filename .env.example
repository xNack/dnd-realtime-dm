# =============================================================================
#  CONFIGURAZIONE — copia questo file in ".env" e inserisci la tua chiave
#      cp .env.example .env
# =============================================================================

# La tua chiave API di Claude (Anthropic).
# Come ottenerla: https://console.anthropic.com  ->  Settings  ->  API Keys
# Deve iniziare con "sk-ant-..."
ANTHROPIC_API_KEY=sk-ant-INSERISCI-QUI-LA-TUA-CHIAVE

# Modello Claude da usare per l'arricchimento (veloce ed economico).
# Alternative: claude-sonnet-4-6 (più bravo, più costoso/lento)
CLAUDE_MODEL=claude-haiku-4-5
